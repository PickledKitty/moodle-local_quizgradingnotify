<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/quizgradingnotify/db" VERSION="2026062401" COMMENT="XMLDB file for local_quizgradingnotify">
  <TABLES>

    <TABLE NAME="local_quizgradingnotify_cfg"
           COMMENT="Per-quiz grading notification method setting">
      <FIELDS>
        <FIELD NAME="id"           TYPE="int"  LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="cmid"         TYPE="int"  LENGTH="10" NOTNULL="true" COMMENT="Course-module ID of the quiz"/>
        <FIELD NAME="method"       TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="none"
               COMMENT="Notification method: none|email|popup"/>
       <FIELD NAME="delayseconds" TYPE="int"  LENGTH="10" NOTNULL="true" DEFAULT="0"
         COMMENT="Delay after acknowledgement before a new notification can be sent: 0|3600|7200"/>
        <FIELD NAME="timecreated"  TYPE="int"  LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int"  LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="cmid"    TYPE="unique"  FIELDS="cmid"/>
      </KEYS>
    </TABLE>

    <TABLE NAME="local_quizgradingnotify_pnd"
          COMMENT="Per-teacher pending notification state per quiz module">
      <FIELDS>
        <FIELD NAME="id"           TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="cmid"         TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Course-module ID of the quiz"/>
        <FIELD NAME="userid"       TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Teacher user ID"/>
        <FIELD NAME="pending"      TYPE="int" LENGTH="1"  NOTNULL="true" DEFAULT="0"
           COMMENT="1 when a notification is outstanding; 0 after acknowledgement"/>
        <FIELD NAME="timesent"     TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timeacked"    TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated"  TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="cmid-userid" TYPE="unique" FIELDS="cmid, userid"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="pending-cmid" UNIQUE="false" FIELDS="pending, cmid"/>
      </INDEXES>
    </TABLE>

  </TABLES>
</XMLDB>
